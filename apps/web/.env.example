# Sanity project configuration
# Find these values at https://www.sanity.io/manage
NEXT_PUBLIC_SANITY_PROJECT_ID=your_project_id
NEXT_PUBLIC_SANITY_DATASET=production
NEXT_PUBLIC_SANITY_API_VERSION=2026-05-26

# Sanity API token — generate a read token at https://www.sanity.io/manage
# Required for Live Content API, Draft Mode, and Visual Editing
SANITY_API_READ_TOKEN=your_read_token_here
