################################################################################
# SETUP INSTRUCTIONS
################################################################################
#
# 1. Copy this file to .env.local in the same directory:
#    cp .env.example .env.local
#
# 2. Fill in each variable below with your actual values (see comments).
#
# 3. IMPORTANT: .env.local is git-ignored; never commit actual secrets.
#    Only .env.example is tracked (this file). Share .env.example publicly.
#
################################################################################

# ─── Public site ────────────────────────────────────────────────────────────
# Name: NEXT_PUBLIC_SITE_URL
# Value: Absolute production URL (no trailing slash)
# Used for: Canonical URLs, hreflang alternate links, sitemap, JSON-LD schemas
# Example: https://mysite.com (production) or http://localhost:3000 (dev)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Name: NEXT_PUBLIC_SITE_NAME
# Value: Fallback brand/site name (optional; Site Settings in Sanity overrides)
# Used for: JSON-LD organization schema if not set in CMS
# Example: My Company Name
NEXT_PUBLIC_SITE_NAME=YourBrand

# ─── Sanity (public credentials — safe to expose in browser) ──────────────────
# Name: NEXT_PUBLIC_SANITY_PROJECT_ID
# Value: Your Sanity project ID
# Find: https://www.sanity.io/manage → Projects → copy project ID
# Example: abc1def2ghi3
NEXT_PUBLIC_SANITY_PROJECT_ID=your_project_id

# Name: NEXT_PUBLIC_SANITY_DATASET
# Value: Dataset name in Sanity (usually 'production')
# Find: https://www.sanity.io/manage → Datasets
# Example: production
NEXT_PUBLIC_SANITY_DATASET=production

# Name: NEXT_PUBLIC_SANITY_API_VERSION
# Value: Sanity API version (YYYY-MM-DD format)
# Note: Must match versions used in studio + web code
# Example: 2026-05-26
NEXT_PUBLIC_SANITY_API_VERSION=2026-05-26

# Name: NEXT_PUBLIC_SANITY_STUDIO_URL
# Value: Where your Sanity Studio is hosted (no trailing slash)
# Used for: Visual editing links back to Presentation tool
# Example: https://studio.sanity.io/projects/abc1def2ghi3 or http://localhost:3333
NEXT_PUBLIC_SANITY_STUDIO_URL=http://localhost:3333

# ─── Sanity (server-only secrets — NEVER expose to browser) ───────────────────
# These must be in .env.local, never in .env.example (except placeholders like below)

# Name: SANITY_API_READ_TOKEN
# Value: API token with read-only access to your dataset
# Required for: Draft Mode / Presentation preview (reading draft documents)
# Generate: https://www.sanity.io/manage → API → Tokens → Add API token
# Role: "Viewer" (read-only) is sufficient
# Example: sk_5a6b7c8d9e0f1a2b3c4d5e6f7a8b9c0d
SANITY_API_READ_TOKEN=your_read_token_here

# Name: SANITY_REVALIDATE_SECRET
# Value: Shared secret between Sanity and this app for webhook validation
# Required for: Validating signed requests from Sanity to /api/revalidate
# Generate: Use a cryptographically secure random string
# Command: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Sanity webhook: set this as the webhook Secret, not a plain Authorization header
# Example: a1b2c3d4e5f6a7b8c9d0e1f2a3b4c5d6e7f8a9b0c1d2e3f4a5b6c7d8e9f0a1
SANITY_REVALIDATE_SECRET=generate_a_long_random_string

# Name: SANITY_PREVIEW_SECRET
# Value: Optional extra secret for gating /api/draft-mode/enable requests
# Required for: Extra security on draft mode activation
# Generate: Use a cryptographically secure random string (same as above command)
# Note: If set, this MUST also be in apps/studio/.env.local as SANITY_STUDIO_PREVIEW_SECRET
# Example: x9y8z7w6v5u4t3s2r1q0p9o8n7m6l5k4j3i2h1g0f9e8d7c6b5a4z3y2x1w0
SANITY_PREVIEW_SECRET=generate_a_long_random_string
