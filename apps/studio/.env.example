################################################################################
# SETUP INSTRUCTIONS
################################################################################
#
# 1. Copy this file to .env.local in the same directory:
#    cp .env.example .env.local
#
# 2. Fill in each variable below with your actual values (see comments).
#
# 3. IMPORTANT: .env.local is git-ignored; never commit actual secrets.
#    Only .env.example is tracked (this file). Share .env.example publicly.
#
################################################################################

# ─── Presentation & Draft Preview ───────────────────────────────────────────
# Name: SANITY_STUDIO_PREVIEW_URL
# Value: URL of the running Next.js web app (no trailing slash)
# Used by: Presentation tool for draft preview; editor preview panels to build live/draft URLs
# Example: http://localhost:3000 (dev) or https://mysite.com (production)
SANITY_STUDIO_PREVIEW_URL=http://localhost:3000

# ─── Server-only Secrets (NEVER expose to browser) ──────────────────────────
# Name: SANITY_STUDIO_PREVIEW_SECRET
# Value: Secret for validating draft mode requests from the studio
# CRITICAL: Must MATCH SANITY_PREVIEW_SECRET in apps/web/.env.local exactly
# Generate: Use a cryptographically secure random string (share the SAME value in both files)
# Command: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Example: a1b2c3d4e5f6a7b8c9d0e1f2a3b4c5d6e7f8a9b0c1d2e3f4a5b6c7d8e9f0a1
#
# SETUP FLOW:
#   1. Generate the secret once (above command)
#   2. Paste it here as SANITY_STUDIO_PREVIEW_SECRET in apps/studio/.env.local
#   3. Paste the SAME value as SANITY_PREVIEW_SECRET in apps/web/.env.local
#   4. Both apps must use identical values for preview to work
SANITY_STUDIO_PREVIEW_SECRET=your_preview_secret_here
