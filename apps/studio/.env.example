################################################################################
# SETUP INSTRUCTIONS
################################################################################
#
# 1. Copy this file to .env.local in the same directory:
#    cp .env.example .env.local
#
# 2. Fill in each variable below with your actual values.
#
# 3. IMPORTANT: .env.local is git-ignored. Never commit real secrets.
#
################################################################################

# --- Sanity project -----------------------------------------------------------
# Name: SANITY_STUDIO_PROJECT_ID
# Value: Sanity project ID used by the Studio.
# Find: https://www.sanity.io/manage -> project -> Project ID
SANITY_STUDIO_PROJECT_ID=your_project_id

# Name: SANITY_STUDIO_DATASET
# Value: Dataset name used by the Studio. Usually "production".
SANITY_STUDIO_DATASET=production

# Name: SANITY_STUDIO_APP_ID
# Value: Optional hosted Studio app ID created by Sanity deploy.
# Note: Leave blank until you deploy a new Studio, or replace with your own app id.
SANITY_STUDIO_APP_ID=your_studio_app_id

# --- Presentation and Draft Preview ------------------------------------------
# Name: SANITY_STUDIO_PREVIEW_URL
# Value: URL of the running Next.js web app, with no trailing slash.
# Examples: http://localhost:3000 or https://your-project.vercel.app
SANITY_STUDIO_PREVIEW_URL=http://localhost:3000

# --- Server-only secret -------------------------------------------------------
# Name: SANITY_STUDIO_PREVIEW_SECRET
# Value: Shared secret for validating draft mode requests from Studio.
# CRITICAL: Must match SANITY_PREVIEW_SECRET in apps/web/.env.local exactly.
# Generate:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SANITY_STUDIO_PREVIEW_SECRET=your_preview_secret_here
